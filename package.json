{
  "name": "borealis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check:rpc": "node scripts/check-rpc.mjs",
    "contracts:compile": "node scripts/compile-contract.mjs",
    "deploy:mezo": "node scripts/deploy-mezo.mjs",
    "deploy:full": "node scripts/deploy-full.mjs",
    "verify:proof": "node scripts/verify-live-proof.mjs",
    "e2e:verify": "node scripts/e2e-verify.mjs",
    "video:studio": "remotion studio remotion/index.ts",
    "video:still": "remotion still remotion/index.ts BorealisPitch out/borealis-pitch-frame.png --frame=240 --overwrite",
    "video:render": "remotion render remotion/index.ts BorealisPitch out/borealis-pitch-ai-inserts.mp4 --concurrency=1 --overwrite",
    "video:render:placeholder": "remotion render remotion/index.ts BorealisPitch out/borealis-pitch-placeholder.mp4 --concurrency=1 --overwrite"
  },
  "dependencies": {
    "@mezo-org/passport": "^0.17.2",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.95",
    "@tanstack/react-query": "^5.100.14",
    "buffer": "^6.0.3",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.553.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.39.3",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@remotion/cli": "^4.0.465",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "remotion": "^4.0.465",
    "solc": "^0.8.30",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.13"
  }
}
